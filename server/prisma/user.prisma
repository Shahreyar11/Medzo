model User {
  id                       Int      @id @default(autoincrement())
  firstName                String
  lastName                 String
  email                    String   @unique
  pendingEmail             String?
  isVerifiedPendingEmail   Boolean  @default(false)
  isVerifiedEmail          Boolean  @default(false)
  mobileNumber             String?  @unique
  isVerifiedMobileNumber   Boolean  @default(false)
  password                 String
  role                     Role     @default(user)
  emailOtp                 String?
  emailOtpExpiry           DateTime?
  mobileNumberOtp          String?
  mobileNumberOtpExpiry    DateTime?
  resetPasswordToken       String?
  resetPasswordExpiresAt   DateTime?

  sessions                 Session[]
  clinic        Clinic?  @relation("ClinicDoctors", fields: [clinicId], references: [id])
  clinicId      String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  appointments  Appointment[] @relation("PatientAppointments")
  doctorSlots   Appointment[] @relation("DoctorAppointments")

  @@map("users")
}

enum Role {
  OWNER
  MANAGER
  DOCTOR
  RECEPTIONIST
  PATIENT
}
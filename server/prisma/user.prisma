model User {
  id                       Int      @id @default(autoincrement())
  firstName                String
  lastName                 String
  email                    String   @unique
  pendingEmail             String?
  isVerifiedPendingEmail   Boolean  @default(false)
  isVerifiedEmail          Boolean  @default(false)
  mobileNumber             String?  @unique
  isVerifiedMobileNumber   Boolean  @default(false)
  password                 String
  role                     Role     @default(user)
  emailOtp                 String?
  emailOtpExpiry           DateTime?
  mobileNumberOtp          String?
  mobileNumberOtpExpiry    DateTime?
  resetPasswordToken       String?
  resetPasswordExpiresAt   DateTime?

  sessions                 Session[]

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("users")
}

enum Role {
  user
  moderator
  admin
  leadAdmin
  manager
}